# font
font-family = "SFMono Nerd Font", "Apple Color Emoji"
font-size = 20

# theme
# catppuccin
# theme = dark:Catppuccin Mocha,light:Catppuccin Latte
# cyberdream
theme = dark:cyberdream,light:cyberdream-light

# background
background-opacity = 0.65
background-blur-radius = 150

# cursor
cursor-style = block_hollow
cursor-invert-fg-bg = true

# move cursor by pressing option+click
cursor-click-to-move = true
shell-integration-features = no-cursor

# window experience
window-padding-balance = true
adjust-cell-height = 35%
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
macos-titlebar-style = hidden 
unfocused-split-opacity = 0.7
confirm-close-surface = false

# quality of life options

# fallback working dir 
working-directory = home 
# new windows will not inherit working dir
window-inherit-working-directory = false 
# save state of previous ghostty sessions
window-save-state = never
